# ── Server ────────────────────────────────────────────────────────────────────
# Port the API server listens on.
PORT=3002

# Runtime environment: development | production | test
NODE_ENV=development

# Allowed CORS origin for the React dev server.
# In production, set this to your actual frontend domain.
CORS_ORIGIN=http://localhost:3000

# ── Blockchain ────────────────────────────────────────────────────────────────
# Number of leading zeros required for a valid block hash (proof-of-work).
# Higher = slower mining, more secure. Default: 2
BLOCKCHAIN_DIFFICULTY=2

# Coins awarded to the miner who successfully mines a block.
BLOCKCHAIN_MINING_REWARD=100

# Address that receives the genesis / demo mining reward on first run.
INITIAL_MINER_ADDRESS=genesis-miner

# ── Persistence ───────────────────────────────────────────────────────────────
# Set to "false" to disable reading from / writing to disk.
# Useful in test environments where you want a fresh chain every run.
BLOCKCHAIN_PERSISTENCE=true

# Absolute or relative path to the JSON file used to persist chain state.
# The file is created automatically on first write.
# Default: blockchain.json in the project root (already gitignored).
BLOCKCHAIN_DATA_FILE=blockchain.json

# ── Demo / Seed data ──────────────────────────────────────────────────────────
# Set to "false" to start with an empty chain (only the genesis block).
# When true and no persisted state exists, two wallets are generated and
# a small set of signed transactions is mined into the chain on startup.
SEED_DEMO_DATA=true

# ── Faucet / Gift coins ───────────────────────────────────────────────────────
# Amount of coins gifted per POST /api/wallets/gift request.
# The faucet is disabled in production regardless of this value.
FAUCET_GIFT_AMOUNT=500

# ── Fee display ───────────────────────────────────────────────────────────────
# Principal and rate used to compute the displayed fee in the Stats panel.
# The fee is informational only — it is not deducted from transactions.
FEE_AMOUNT=100
FEE_PERCENTAGE=2.5
