{
  "name": "blockchain-hometask",
  "version": "1.0.0",
  "description": "Blockchain HomeTask Project with integrated frontend and backend",
  "main": "server.js",
  "scripts": {
    "start": "react-scripts start",
    "server": "node server.js",
    "dev": "nodemon server.js",
    "build": "react-scripts build",
    "serve": "npm run build && npm run server",
    "prod": "npm run serve",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css}\"",
    "typecheck": "tsc --noEmit",
    "build:ts": "tsc -p tsconfig.json",
    "ci": "npm run lint && npm run test",
    "prepare": "husky install"
  },
  "keywords": [
    "blockchain",
    "crypto",
    "react",
    "express"
  ],
  "author": "",
  "license": "OMG",
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "http-proxy-middleware": "^2.0.6",
    "morgan": "^1.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "request": "^2.88.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "typescript": "^4.9.5",
    "ts-node": "^10.9.1",
    "@types/node": "^20.5.1",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "eslint": "^8.45.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "prettier": "^2.8.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",    
    "@types/jest": "^29.5.4",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^14.0.0",
    "supertest": "^6.2.4",
    "@types/supertest": "^2.0.13",
    "eslint-plugin-import": "^2.28.1",
    "concurrently": "^8.2.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
